<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>読み取りページ</title>

    <script src="/js/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/quagga@0.12.1/dist/quagga.min.js"></script>

    <link rel="stylesheet" href="/styles/ReadCode.css" />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <meta name="robots" content="noindex" />

    <style>
      .status-panel {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 10px;
        padding: 20px;
        margin: 20px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        text-align: center;
      }

      .status-title {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 10px;
        color: #333;
      }

      .status-message {
        font-size: 16px;
        margin-bottom: 15px;
        color: #666;
      }

      .status-indicator {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 10px;
        background: #ccc;
      }

      .status-indicator.active {
        background: #28a745;
        animation: pulse 1.5s infinite;
      }

      .status-indicator.waiting {
        background: #ffc107;
        animation: pulse 1.5s infinite;
      }

      .status-indicator.error {
        background: #dc3545;
      }

      @keyframes pulse {
        0% {
          opacity: 1;
        }
        50% {
          opacity: 0.5;
        }
        100% {
          opacity: 1;
        }
      }

      .progress-bar {
        width: 100%;
        height: 8px;
        background: #e9ecef;
        border-radius: 4px;
        overflow: hidden;
        margin: 15px 0;
      }

      .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #007bff, #28a745);
        width: 0%;
        transition: width 0.3s ease;
      }

      .barcode-info {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 5px;
        padding: 10px;
        margin: 10px 0;
        font-family: monospace;
        font-size: 14px;
      }

      .success-animation {
        animation: successPulse 0.6s ease;
      }

      @keyframes successPulse {
        0% {
          transform: scale(1);
        }
        50% {
          transform: scale(1.05);
        }
        100% {
          transform: scale(1);
        }
      }

      .error-message {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
        border-radius: 5px;
        padding: 12px;
        margin: 10px 0;
        display: none;
      }

      .success-message {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
        border-radius: 5px;
        padding: 12px;
        margin: 10px 0;
        display: none;
      }
    </style>
  </head>

  <body>
    <%- include('Header') %>

    <section id="read-code">
      <!-- 左側ボタンエリア -->
      <div class="buttons">
        <button class="animation-btn" onclick="location.href = '/main'">
          ←戻る
        </button>
        <button class="animation-btn" onclick="location.reload()">
          最初から
        </button>
        <button id="toggle-mode-btn" class="animation-btn">貸出モード</button>
      </div>

      <!-- 中央ステータスパネル -->
      <div class="status-panel">
        <div class="status-title">
          <span class="status-indicator" id="status-indicator"></span>
          <span id="status-text">準備中...</span>
        </div>
        <div class="status-message" id="status-message">
          ユーザーカードをスキャンしてください
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
        <div id="barcode-info-container"></div>
        <div class="error-message" id="error-message"></div>
        <div class="success-message" id="success-message"></div>
      </div>

      <!-- 右側カメラビューエリア -->
      <div id="read-view">
        <div id="interactive"></div>
        <canvas class="drawRect"></canvas>
      </div>
    </section>
    <input type="text" id="hidden-barcode-input" maxlength="13" />
    <%- include('Footer') %>
    <script src="/js/ReadCode.js"></script>
  </body>
</html>
