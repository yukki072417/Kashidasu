<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>読み取りページ</title>

    <script src="/js/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/quagga@0.12.1/dist/quagga.min.js"></script>

    <link rel="stylesheet" href="/styles/ReadCode.css" />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <meta name="robots" content="noindex" />
  </head>

  <body>
    <%- include('Header') %>

    <section id="read-code">
      <!-- 左カラム -->
      <div class="left-column">
        <div class="buttons">
          <button class="animation-btn" onclick="location.href = '/main'">
            ←戻る
          </button>
          <button class="animation-btn" onclick="location.reload()">
            最初から
          </button>
          <button id="toggle-mode-btn" class="animation-btn">貸出モード</button>
        </div>

        <div class="status-panel">
          <div class="status-title">
            <span class="status-indicator" id="status-indicator"></span>
            <span id="status-text">準備中...</span>
          </div>
          <div class="status-message" id="status-message">
            ユーザーカードをスキャンしてください
          </div>
          <div class="progress-bar">
            <div class="progress-fill" id="progress-fill"></div>
          </div>
          <div id="barcode-info-container"></div>
          <div class="error-message" id="error-message"></div>
          <div class="success-message" id="success-message"></div>
        </div>

        <div class="manual-input">
          <label>手入力バーコード:</label>
          <input type="text" id="manual-barcode-input" maxlength="13" />
        </div>
      </div>

      <!-- 右カラム（カメラ） -->
      <div id="read-view">
        <div id="interactive"></div>
        <canvas class="drawRect"></canvas>
      </div>
    </section>

    <input type="text" id="hidden-barcode-input" maxlength="13" />
    <%- include('Footer') %>
    <script src="/js/readCode.js"></script>
  </body>
</html>
